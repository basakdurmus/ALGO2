 public static void main(String[] args) throws FileNotFoundException {


                String icerik = "";

                try {
                    FileReader fr = new FileReader("selam.txt");
                    int karakter;

                    // Dosyayı oku
                    while ((karakter = fr.read()) != -1) {
                        icerik += (char) karakter;
                    }
                    fr.close();

                    // Ters çevir
                    String ters = "";
                    for (int i = icerik.length() - 1; i >= 0; i--) {
                        ters += icerik.charAt(i);
                    }

                    // Yeni dosyaya yaz
                    FileWriter fw = new FileWriter("meyve.txt");
                    fw.write(ters);
                    fw.close();

                    System.out.println("Ters çevirme tamam!");

                } catch (IOException e) {
                    System.out.println("Hata oluştu!");
                }
            }
        }

