import java.io.PrintWriter;
import java.io.IOException;
import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        
        // 1. Kullanıcıdan veri almak için Scanner, dosyaya yazmak için PrintWriter açıyoruz
        // Try-with-resources kullandık ki iş bitince her ikisi de otomatik kapansın
        try (Scanner klavye = new Scanner(System.in);
             PrintWriter yazici = new PrintWriter("meyveler.txt")) {
            
            System.out.println("Lütfen en sevdiğiniz 5 meyveyi girin:");

            // 2. Döngü başlıyor: 0'dan 5'e kadar (toplam 5 kez)
            for (int i = 1; i <= 5; i++) {
                System.out.print(i + ". meyve: ");
                String meyve = klavye.nextLine(); // Kullanıcının yazdığını oku
                
                yazici.println(meyve); // Dosyaya alt alta yaz
            }
            
            System.out.println("\nHarika! Meyveler 'meyveler.txt' dosyasına kaydedildi.");

        } catch (IOException e) {
            System.out.println("Dosya oluşturulurken bir hata çıktı: " + e.getMessage());
        }
    }
}
